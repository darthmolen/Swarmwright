# AgentMemoryOS local-dev environment.
# Copy to .env and adjust as needed: `cp .env.example .env`
# docker-compose.yml and scripts read these values via ${VAR} interpolation.

# --- PostgreSQL (pgvector) ---
POSTGRES_USER=agentmemory
POSTGRES_PASSWORD=agentmemory
POSTGRES_DB=agentmemory
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- vLLM (OpenAI-compatible model server, opt-in "gpu" profile) ---
VLLM_PORT=8000
# A Qwen instruct model with solid tool-calling support.
# Qwen2.5-7B-Instruct is a safe default that fits comfortably in 32GB.
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# Override the image if you need a from-source build (e.g. Blackwell/sm_120).
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MAX_MODEL_LEN=32768
# Optional: only needed for gated/private models on the Hugging Face Hub.
HUGGING_FACE_HUB_TOKEN=

# --- App-facing memory provider settings ---
# Where memories are stored: inmemory | postgres
MEMORY_STORE=inmemory
# Toggle Redis-backed caching/features.
REDIS_ENABLED=false
# Chat/completions endpoint used by the memory provider (points at vLLM by default).
MEMORY_CHAT_ENDPOINT=http://localhost:8000/v1
MEMORY_CHAT_MODEL=${VLLM_MODEL}
# vLLM ignores the key, but the OpenAI client requires a non-empty value.
MEMORY_CHAT_API_KEY=local-dev-key

# --- Connection string (ConnectionStrings__Postgres) ---
POSTGRES_CONNECTION="Host=localhost;Port=5432;Username=agentmemory;Password=agentmemory;Database=agentmemory"
