# Swarmwright local-dev environment.
# Copy to .env and adjust as needed: `cp .env.example .env`
# docker-compose.yml and scripts/* read these values via ${VAR} interpolation.
# (The .NET app does NOT read this file — it uses appsettings.json + environment variables.)

# --- PostgreSQL (optional) ---
# The app defaults to the InMemory provider; set Swarm:Database:Provider=PostgreSQL in appsettings
# (with a matching Swarm:Database:ConnectionString) to use this container.
POSTGRES_USER=swarmwright
POSTGRES_PASSWORD=swarmwright
POSTGRES_DB=swarmwright
POSTGRES_PORT=5432

# --- vLLM (OpenAI-compatible model server, opt-in "gpu" profile) ---
VLLM_PORT=8000
# A Qwen instruct model with solid tool-calling support; fits comfortably in 32GB.
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# Override the image if you need a from-source build (e.g. Blackwell/sm_120).
VLLM_IMAGE=vllm/vllm-openai:latest
VLLM_MAX_MODEL_LEN=32768
# Optional: only needed for gated/private models on the Hugging Face Hub.
HUGGING_FACE_HUB_TOKEN=

# --- Microsoft Agent Framework / Azure AI Foundry ---
# Kept for future use; not consumed by anything yet.
MAF_AIF_ENDPOINT=
MAF_AIF_API_KEY=
MAF_AIF_MODEL=
